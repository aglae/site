---
import WritingPiece from '../../views/WritingPiece.astro';
import { getPieces, pieceSlug } from '../../lib/forest';

export async function getStaticPaths() {
  const pieces = await getPieces('en');
  return pieces.map((piece) => ({
    params: { slug: pieceSlug(piece) },
    props: { piece },
  }));
}

const { piece } = Astro.props;
---

<WritingPiece lang="en" piece={piece} />
